"""
该代码用来实现对Sentinel-2A影像的归一化处理，NDVI,NDWI的归一化处理
方式一：直接基于Sentinel-2A归一化后的影像计算NDVI,NDWI，并进行波段叠加，形成12波段影像
备注：使用原始波段数据（未归一化）计算 NDVI 和 NDWI，确保指数的物理意义。
     对计算得到的 NDVI 和 NDWI 进行归一化，范围同样缩放到 [0, 1]。
     NDWI 用于提取地表水体，NDMI 用于监测植被水分。
     这里以NDWI为例进行示例计算，请结合实际需要进行修改

"""

from osgeo import gdal
import numpy as np
import os

# 输入和输出文件路径
input_file = r"E:\XXXX\X.tif"
output_file = r"E:\X\Process_img\X.tif"

# 检查输入文件是否存在
if not os.path.exists(input_file):
    raise FileNotFoundError(f"输入文件不存在: {input_file}")

# 检查输出文件路径是否可写
output_dir = os.path.dirname(output_file) or "."
if not os.access(output_dir, os.W_OK):
    raise PermissionError(f"输出目录不可写: {output_dir}")

# 打开输入影像
dataset = gdal.Open(input_file, gdal.GA_ReadOnly)
if dataset is None:
    raise Exception("无法打开输入文件")

# 获取影像基本信息
rows = dataset.RasterYSize
cols = dataset.RasterXSize
bands = dataset.RasterCount  # 假设为10波段
projection = dataset.GetProjection()
geotransform = dataset.GetGeoTransform()

print(f"输入影像信息: 行={rows}, 列={cols}, 波段数={bands}")

# 读取并归一化10个波段
band_data = []
for i in range(1, bands + 1):
    band = dataset.GetRasterBand(i)
    nodata_value = band.GetNoDataValue() or 0  # 如果未定义，默认设为 0
    print(f"波段 {i} 的 NoData 值: {nodata_value}")

    data = band.ReadAsArray().astype(float)
    data = np.where(data == nodata_value, np.nan, data)  # 替换 NoData 为 NaN

    data_min = np.nanmin(data)
    data_max = np.nanmax(data)
    print(f"波段 {i}: min={data_min}, max={data_max}")

    if np.isnan(data_min) or np.isnan(data_max):
        print(f"波段 {i} 数据全为 NaN，设为 0")
        data_normalized = np.zeros_like(data)
    elif data_max == data_min:
        print(f"波段 {i} 数据值全相同，设为 0")
        data_normalized = np.zeros_like(data)
    else:
        data_normalized = (data - data_min) / (data_max - data_min)

    data_normalized = np.nan_to_num(data_normalized, nan=0.0)
    band_data.append(data_normalized)

# 计算 NDVI 和 NDWI（基于原始数据）
# 假设 Sentinel-2 波段顺序为 B1-B12（10波段可能是子集），使用 B03 (Green), B04 (Red), B08 (NIR)
# 如果波段映射不同，请根据实际数据调整
band_green = dataset.GetRasterBand(2).ReadAsArray().astype(float)  # B03
band_red = dataset.GetRasterBand(3).ReadAsArray().astype(float)  # B04
band_nir = dataset.GetRasterBand(7).ReadAsArray().astype(float)  # B08

nodata_value = dataset.GetRasterBand(1).GetNoDataValue() or 0
band_green = np.where(band_green == nodata_value, np.nan, band_green)
band_red = np.where(band_red == nodata_value, np.nan, band_red)
band_nir = np.where(band_nir == nodata_value, np.nan, band_nir)

# NDVI = (NIR - Red) / (NIR + Red)
ndvi = np.where((band_nir + band_red) == 0, np.nan, (band_nir - band_red) / (band_nir + band_red))
# NDWI = (Green - NIR) / (Green + NIR)
ndwi = np.where((band_green + band_nir) == 0, np.nan, (band_green - band_nir) / (band_green + band_nir))

# 归一化 NDVI 和 NDWI
ndvi_min, ndvi_max = np.nanmin(ndvi), np.nanmax(ndvi)
ndwi_min, ndwi_max = np.nanmin(ndwi), np.nanmax(ndwi)

if np.isnan(ndvi_min) or np.isnan(ndvi_max):
    print("NDVI 数据全为 NaN，设为 0")
    ndvi_normalized = np.zeros_like(ndvi)
else:
    ndvi_normalized = (ndvi - ndvi_min) / (ndvi_max - ndvi_min)

if np.isnan(ndwi_min) or np.isnan(ndwi_max):
    print("NDWI 数据全为 NaN，设为 0")
    ndwi_normalized = np.zeros_like(ndwi)
else:
    ndwi_normalized = (ndwi - ndwi_min) / (ndwi_max - ndwi_min)

ndvi_normalized = np.nan_to_num(ndvi_normalized, nan=0.0)
ndwi_normalized = np.nan_to_num(ndwi_normalized, nan=0.0)

# 创建输出影像（10波段 + NDVI + NDWI = 12波段）
driver = gdal.GetDriverByName("GTiff")
if driver is None:
    raise Exception("无法加载 GTiff 驱动")

out_dataset = driver.Create(output_file, cols, rows, bands + 2, gdal.GDT_Float32)
if out_dataset is None:
    raise Exception(f"创建输出文件失败: {output_file}")

out_dataset.SetProjection(projection)
out_dataset.SetGeoTransform(geotransform)

# 写入归一化的10个原始波段
for i in range(bands):
    out_dataset.GetRasterBand(i + 1).WriteArray(band_data[i])
    out_dataset.GetRasterBand(i + 1).SetDescription(f"Band_{i + 1}_Normalized")

# 写入归一化的 NDVI 和 NDWI
out_dataset.GetRasterBand(bands + 1).WriteArray(ndvi_normalized)
out_dataset.GetRasterBand(bands + 1).SetDescription("NDVI_Normalized")
out_dataset.GetRasterBand(bands + 2).WriteArray(ndwi_normalized)
out_dataset.GetRasterBand(bands + 2).SetDescription("NDWI_Normalized")

# 调试：打印示例数据
print("波段 1 的第二行数据示例:", band_data[0][1][:10])
print("NDVI 的第二行数据示例:", ndvi_normalized[1][:10])
print("NDWI 的第二行数据示例:", ndwi_normalized[1][:10])

# 关闭文件
dataset = None
out_dataset = None

print("处理完成，新影像已保存为:", output_file)
